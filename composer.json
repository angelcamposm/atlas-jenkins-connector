{
    "name": "acamposm/atlas-jenkins-connector",
    "description": "A PHP connector for the Jenkins API.",
    "type": "library",
    "license": "MIT",
    "version": "0.1.0",
    "authors": [
        {
            "name": "Angel Campos",
            "email": "angel.campos.m@gmail.com"
        }
    ],
    "require": {
        "php": "^8.5",
        "guzzlehttp/guzzle": "^7.8",
        "symfony/polyfill-mbstring": "^1.31"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Atlas\\Connectors\\Jenkins\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Atlas\\Connectors\\Jenkins\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "scripts": {
        "test": "phpunit --coverage-text",
        "analyse": "phpstan analyse",
        "format": "php-cs-fixer fix"
    },
    "minimum-stability": "stable"
}
